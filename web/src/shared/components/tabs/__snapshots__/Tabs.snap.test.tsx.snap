// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Tabs snapshots > renders tabs in dark mode 1`] = `
<div
  class="flex flex-col"
>
  <div
    aria-orientation="horizontal"
    class="flex border-b border-[var(--color-on-surface)]/10"
    role="tablist"
  >
    <button
      aria-controls="_r_0_-panel-tab1"
      aria-selected="true"
      class="relative px-4 py-2.5 text-sm font-display font-medium transition-colors duration-[var(--duration-fast)] ease-[var(--ease-out-expo)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/40 focus-visible:ring-inset text-[var(--color-brand)]"
      data-tab-value="tab1"
      id="_r_0_-tab-tab1"
      role="tab"
      tabindex="0"
      type="button"
    >
      Tab 1
      <span
        class="absolute bottom-0 left-2 right-2 h-0.5 rounded-full bg-[var(--color-brand)]"
      />
    </button>
    <button
      aria-controls="_r_0_-panel-tab2"
      aria-selected="false"
      class="relative px-4 py-2.5 text-sm font-display font-medium transition-colors duration-[var(--duration-fast)] ease-[var(--ease-out-expo)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/40 focus-visible:ring-inset text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)]"
      data-tab-value="tab2"
      id="_r_0_-tab-tab2"
      role="tab"
      tabindex="-1"
      type="button"
    >
      Tab 2
    </button>
    <button
      aria-controls="_r_0_-panel-tab3"
      aria-disabled="true"
      aria-selected="false"
      class="relative px-4 py-2.5 text-sm font-display font-medium transition-colors duration-[var(--duration-fast)] ease-[var(--ease-out-expo)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/40 focus-visible:ring-inset text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)] cursor-not-allowed opacity-40"
      data-tab-value="tab3"
      disabled=""
      id="_r_0_-tab-tab3"
      role="tab"
      tabindex="-1"
      type="button"
    >
      Tab 3
    </button>
  </div>
  <div
    aria-labelledby="_r_0_-tab-tab1"
    class="pt-4"
    id="_r_0_-panel-tab1"
    role="tabpanel"
  >
    <p>
      Content 1
    </p>
  </div>
</div>
`;

exports[`ToggleGroup snapshots > renders toggle group in dark mode 1`] = `
