{
  "name": "nexus-talent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @nexus-talent/web dev",
    "dev:server": "pnpm --filter @nexus-talent/server dev",
    "build:web": "pnpm --filter @nexus-talent/web build",
    "build:server": "pnpm --filter @nexus-talent/server build",
    "prisma:generate": "pnpm --filter @nexus-talent/server prisma:generate",
    "prisma:migrate": "pnpm --filter @nexus-talent/server prisma:migrate",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @nexus-talent/e2e test"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3"
}
