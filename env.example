# ═══════════════════════════════════════════════════════════
# Nexus Talent V1.1 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The server reads from process.env; web reads VITE_* vars.
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/nexus-talent
JWT_SECRET=change-me-to-a-random-64-char-string
CORS_ORIGIN=http://localhost:5173

# ── AI (server-side, never exposed) ───────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Supabase (used for DB + optional OAuth verification) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google OAuth ──────────────────────────────────────────
# Leave empty to disable Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Frontend (VITE_*) ─────────────────────────────────────
# These are consumed by the web package at build time.
# VITE_APP_URL is used for the production SPA URL.
VITE_APP_URL=http://localhost:5173
