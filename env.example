# ═══════════════════════════════════════════════════════════
# Nexus Talent V1.1 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The server reads from process.env; web reads VITE_* vars.
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/nexus-talent
JWT_SECRET=change-me-to-a-random-64-char-string
CORS_ORIGIN=http://localhost:5173

# ── AI (server-side, never exposed) ───────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Supabase (used for DB + optional OAuth verification) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google OAuth ──────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback
CLIENT_URL=http://localhost:5173

# ── Code Exchange (must match on Render + Vercel) ────────────
# Shared secret that the Vercel Edge Function uses to authenticate
# POST requests to Render's /api/auth/exchange endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXCHANGE_SECRET=change-me-to-a-64-hex-char-secret

# ── Frontend (VITE_*) ─────────────────────────────────────
# These are consumed by the web package at build time.
# VITE_APP_URL is used for the production SPA URL.
VITE_APP_URL=http://localhost:5173
